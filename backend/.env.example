MONGO_URI=mongodb://localhost:27018
MONGO_DB_NAME=lasdpc
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:8080
BACKEND_PORT=8000
ADMIN_EMAIL=admin@lasdpc.usp.br
ADMIN_PASSWORD=suaSenhaSegura
ADMIN_NAME=Admin LASDPC

# ===== MinIO / S3 =====
# Estas variáveis são usadas tanto pelo backend (boto3) quanto pelos containers
# minio/minio-init via `env_file: ./backend/.env` no docker-compose.yml.

# Credenciais root do MinIO. Geradas com: openssl rand -base64 32
MINIO_ROOT_USER=lasdpc_admin
MINIO_ROOT_PASSWORD=change_me_to_a_strong_password

# Bucket criado automaticamente pelo container minio-init
MINIO_BUCKET=lasdpc-media

# Endpoint interno usado pelo backend para fazer upload
MINIO_ENDPOINT=http://localhost:9000

# URL pública das imagens (bucket incluído). Frontend usa VITE_MINIO_PUBLIC_URL análogo.
# Dev: http://localhost:9000/lasdpc-media | Prod: https://cdn.lasdpc.usp.br/lasdpc-media
MINIO_PUBLIC_URL=http://localhost:9000/lasdpc-media

# CORS no servidor MinIO. Separe múltiplas origens por vírgula.
MINIO_API_CORS_ALLOW_ORIGIN=http://localhost:8080

# URL pública do console admin do MinIO (redirecionamento de login)
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
