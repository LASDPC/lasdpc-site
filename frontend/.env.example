# Copie este arquivo para .env e ajuste os valores
#
# Em desenvolvimento deixe vazio — o proxy do Vite encaminha /api para o backend
# Em produção defina a URL completa do backend, ex: http://192.168.1.10:8000
VITE_API_URL=

# Porta do backend usada pelo proxy do Vite em desenvolvimento (padrão: 8000)
VITE_BACKEND_PORT=8000
